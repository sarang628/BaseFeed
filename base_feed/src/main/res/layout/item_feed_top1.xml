<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="review_id"
            type="Integer" />

        <variable
            name="user_id"
            type="Integer" />

        <variable
            name="restaurant_id"
            type="Integer" />

        <variable
            name="profile_pic_url"
            type="String" />

        <variable
            name="userName"
            type="String" />

        <variable
            name="restaurantName"
            type="String" />

        <variable
            name="rating"
            type="Float" />


        <variable
            name="menuClickListener"
            type="com.sarang.base_feed.CustomClick&lt;Integer&gt; " />

        <variable
            name="profileClickListener"
            type="com.sarang.base_feed.CustomClick&lt;Integer&gt; " />

        <variable
            name="clickRestaurantListener"
            type="com.sarang.base_feed.CustomClick&lt;Integer&gt; " />


        <import type="android.view.View" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp">

        <ImageView
            android:id="@+id/toolbar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:onClick="@{()->menuClickListener.invoke(review_id)}"
            android:padding="10dp"
            android:src="@drawable/ic_dot"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imageView2"
            loadCircleImage="@{profile_pic_url}"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:onClick="@{()->profileClickListener.invoke(user_id)}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:srcCompat="@tools:sample/avatars" />

        <TextView
            android:id="@+id/textView22"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="@{()->profileClickListener.invoke(user_id)}"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:text="@{userName}"
            android:textColor="#000000"
            app:layout_constraintBottom_toTopOf="@+id/tv_restaurant"
            app:layout_constraintStart_toEndOf="@+id/imageView2"
            app:layout_constraintTop_toTopOf="@+id/imageView2"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="name" />

        <TextView
            android:id="@+id/tv_restaurant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="@{()->profileClickListener.invoke(restaurant_id)}"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:text="@{restaurantName}"
            app:layout_constraintBottom_toBottomOf="@+id/imageView2"
            app:layout_constraintStart_toStartOf="@+id/textView22"
            app:layout_constraintTop_toBottomOf="@+id/textView22"
            tools:text="restaurant"
            tools:visibility="visible" />

        <RatingBar
            android:id="@+id/ratingBar4"
            style="@style/Widget.AppCompat.RatingBar.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:rating="@{rating}"
            android:visibility="@{rating == null ? View.GONE : View.VISIBLE}"
            app:layout_constraintBottom_toBottomOf="@+id/textView22"
            app:layout_constraintStart_toEndOf="@+id/textView22"
            app:layout_constraintTop_toTopOf="@+id/textView22" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>